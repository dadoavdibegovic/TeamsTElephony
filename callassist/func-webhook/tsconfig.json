{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": "..",
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      "libphonenumber-js": ["./node_modules/libphonenumber-js"],
      "libphonenumber-js/*": ["./node_modules/libphonenumber-js/*"]
    }
  },
  "include": ["src/**/*", "../shared/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "src/**/*.test.ts",
    "../shared/**/*.test.ts"
  ]
}