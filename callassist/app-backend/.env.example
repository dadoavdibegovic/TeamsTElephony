# --- ACS ---
ACS_CONNECTION_STRING=endpoint=https://<acs>.communication.azure.com/;accesskey=...
# Public URL the ACS Call Automation callbacks reach (e.g. https://app-x.azurewebsites.net)
CALLBACK_BASE_URL=https://app-calltranskript-backend.azurewebsites.net

# --- Entra (Graph) ---
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# --- CRM (SGB) ---
CRM_BASE_URL=https://crm.sgb-energie.de
CRM_API_KEY=

# --- Azure SignalR ---
SIGNALR_CONNECTION_STRING=Endpoint=https://<signalr>.service.signalr.net;AccessKey=...;Version=1.0;

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://<region>.api.cognitive.microsoft.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-calltranskript

# --- Azure Speech ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westeurope
AZURE_SPEECH_LOCALE=de-DE

# --- Optional ---
APPLICATIONINSIGHTS_CONNECTION_STRING=
NODE_ENV=development
PORT=3000

# Comma-separated origins allowed to call /negotiate, /audio, etc. via CORS.
# Leave unset/empty to allow any origin (current behaviour). In production set
# this to your agent-ui origin(s), e.g.
#   ALLOWED_ORIGINS=https://agentui.sgb-energie.de,http://localhost:5173
ALLOWED_ORIGINS=
